# RaagWeather Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
# Base URL for your backend API
VITE_API_BASE_URL=https://api.yourbackend.com

# Weather API
# Get your API key from https://openweathermap.org/api or https://www.weatherapi.com/
VITE_WEATHER_API_KEY=your_weather_api_key_here

# Google OAuth
# Get your client ID from https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Spotify API (optional, for import features)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Feature Flags
# Enable or disable features
VITE_ENABLE_SOCIAL_LOGIN=true
VITE_ENABLE_PARTY_MODE=true
VITE_ENABLE_PREMIUM_FEATURES=true

# Analytics (optional)
VITE_ANALYTICS_ID=your_analytics_id_here

# Sentry (optional, for error tracking)
VITE_SENTRY_DSN=your_sentry_dsn_here

# Environment
# development, staging, or production
VITE_ENV=development
